#. Plugin Name of the plugin
msgid "ELOQIO AI Content Reservation"
msgstr "ELOQIO AI Content Reservation"

#. Plugin URI of the plugin
msgid "https://github.com/eloqio/eloqio-ai-content-reservation"
msgstr "https://github.com/eloqio/eloqio-ai-content-reservation"

#. Description of the plugin
msgid "Implements the W3C TDM Reservation Protocol to signal AI training opt-out on your WordPress content. Exposes /.well-known/tdmrep.json, a tdm-reservation HTTP header, and a matching HTML meta tag."
msgstr "Implémente le W3C TDM Reservation Protocol pour signaler le refus d'entraînement IA sur votre contenu WordPress. Expose /.well-known/tdmrep.json, un en-tête HTTP tdm-reservation et une balise meta HTML correspondante."

#. Author of the plugin
msgid "ELOQIO"
msgstr "ELOQIO"

#. Author URI of the plugin
msgid "https://eloq.io"
msgstr "https://eloq.io"

msgid "AI Content Reservation"
msgstr "Réservation de contenu IA"

msgid "Reservation settings"
msgstr "Paramètres de réservation"

msgid "Enable protocol"
msgstr "Activer le protocole"

msgid "Reservation value"
msgstr "Valeur de réservation"

msgid "Policy URL (optional)"
msgstr "URL de la politique (optionnel)"

msgid "Configure how this site signals its Text & Data Mining reservation to AI crawlers, per the W3C TDM Reservation Protocol."
msgstr "Configurez la manière dont ce site signale la réservation de ses droits de fouille de textes et données aux robots IA, conformément au W3C TDM Reservation Protocol."

msgid "Serve the endpoint, header and meta tag"
msgstr "Servir le endpoint, l'en-tête HTTP et la balise meta"

msgid "1 — Rights reserved (opt-out)"
msgstr "1 — Droits réservés (opt-out)"

msgid "0 — Rights not reserved (opt-in)"
msgstr "0 — Droits non réservés (opt-in)"

msgid "Optional URL of a human-readable policy document describing your reservation terms."
msgstr "URL optionnelle d'un document de politique lisible décrivant vos conditions de réservation."

msgid "Endpoint"
msgstr "Endpoint"

msgid "Your TDMRep endpoint is served at:"
msgstr "Votre endpoint TDMRep est servi à l'adresse :"

msgid "Open the URL above in a new tab to verify that it returns valid JSON. The Site Health screen also runs an automated check."
msgstr "Ouvrez l'URL ci-dessus dans un nouvel onglet pour vérifier qu'elle renvoie un JSON valide. L'écran État de santé du site lance aussi une vérification automatique."

msgid "Settings"
msgstr "Réglages"

msgid "TDMRep endpoint reachability"
msgstr "Accessibilité du endpoint TDMRep"

msgid "The plugin is installed but currently disabled. No TDMRep signal is being sent."
msgstr "Le plugin est installé mais actuellement désactivé. Aucun signal TDMRep n'est envoyé."

#. translators: %s: error message.
#, php-format
msgid "The TDMRep endpoint could not be reached: %s"
msgstr "Le endpoint TDMRep n'a pas pu être contacté : %s"

#. translators: %d: HTTP status code.
#, php-format
msgid "The TDMRep endpoint returned an unexpected response (HTTP %d)."
msgstr "Le endpoint TDMRep a renvoyé une réponse inattendue (HTTP %d)."

msgid "The TDMRep endpoint responds with valid JSON. Your AI reservation signal is live."
msgstr "Le endpoint TDMRep répond avec un JSON valide. Votre signal de réservation IA est actif."
